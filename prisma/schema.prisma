generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  image     String?
  places    Place[]
  userFriends UserFriends[] @relation("UserAsUser")
  friendOf    UserFriends[] @relation("UserAsFriend")
  createdAt DateTime @default(now())
}
model UserFriends {
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user    User @relation("UserAsUser", fields: [userId], references: [id])
  friend  User @relation("UserAsFriend", fields: [friendId], references: [id])

  @@id([userId, friendId])
}


model Place {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  latitude    Float
  longitude   Float
  photos      String[]
  createdBy   User     @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime @default(now())
}
