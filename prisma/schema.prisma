generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  image     String?
  userFriends UserFriends[] @relation("UserAsUser")
  friendOf    UserFriends[] @relation("UserAsFriend")
  reviews   Review[]
  reviewFriends ReviewFriend[] @relation("UserAsReviewFriend") // 👈 тук
  createdAt DateTime @default(now())
}

model UserFriends {
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user    User @relation("UserAsUser", fields: [userId], references: [id])
  friend  User @relation("UserAsFriend", fields: [friendId], references: [id])

  @@id([userId, friendId])
}


model Review {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String

  rating    Int      @default(0)

  comment   String

  placeName String
  longitude Float
  latitude  Float

  friends   ReviewFriend[]

  createdAt DateTime @default(now())
}

model ReviewFriend {
  id        String  @id @default(cuid())
  review    Review  @relation(fields: [reviewId], references: [id])
  reviewId  String

  friend    User    @relation("UserAsReviewFriend", fields: [friendId], references: [id])
  friendId  String
}

