generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  firstname String?
  lastname  String?
  email     String   @unique
  password  String?
  image     String?
  userFriends UserFriends[] @relation("UserAsUser")
  friendOf    UserFriends[] @relation("UserAsFriend")
  reviews   Review[]
  reviewFriends ReviewFriend[] @relation("UserAsReviewFriend")

  chatUsers ChatUser[]

  sentMessages Message[] @relation("UserMessages")

  createdAt DateTime @default(now())
}

model UserFriends {
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user    User @relation("UserAsUser", fields: [userId], references: [id])
  friend  User @relation("UserAsFriend", fields: [friendId], references: [id])

  @@id([userId, friendId])
}


model Review {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String

  rating    Int      @default(0)

  comment   String

  placeName String
  longitude Float
  latitude  Float

  friends   ReviewFriend[]

  createdAt DateTime @default(now())
  isShared  Boolean  @default(false)
}

model ReviewFriend {
  id        String  @id @default(cuid())
  review    Review  @relation(fields: [reviewId], references: [id])
  reviewId  String

  friend    User    @relation("UserAsReviewFriend", fields: [friendId], references: [id])
  friendId  String
}

model Chat {
  id        String    @id @default(cuid())
  users     ChatUser[]
  messages  Message[]
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())
}

model ChatUser {
  chatId String
  userId String

  chat Chat @relation(fields: [chatId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@id([chatId, userId])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  chat   Chat @relation(fields: [chatId], references: [id])

  sender User @relation("UserMessages", fields: [senderId], references: [id])
}